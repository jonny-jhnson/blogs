---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const slugifyTag = (t) => t.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

export async function getStaticPaths() {
  const slug = (t) => t.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  // Map each tag-slug to its display name + matching posts.
  const byTag = new Map();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      const key = slug(tag);
      if (!byTag.has(key)) byTag.set(key, { display: tag, posts: [] });
      byTag.get(key).posts.push(post);
    }
  }

  return [...byTag.entries()].map(([key, { display, posts }]) => ({
    params: { tag: key },
    props: {
      tag: display,
      posts: posts.sort((a, b) => {
        const ao = a.data.order ?? Infinity;
        const bo = b.data.order ?? Infinity;
        if (ao !== bo) return ao - bo;
        return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
      }),
    },
  }));
}

const { tag, posts } = Astro.props;

const fmtDate = (d) => {
  const dt = new Date(d);
  const p = (n) => String(n).padStart(2, '0');
  return `${dt.getFullYear()}·${p(dt.getMonth() + 1)}·${p(dt.getDate())}`;
};
---
<BaseLayout title={`#${tag}`} description={`Posts tagged ${tag}.`}>
  <section class="wrap tag-head">
    <div class="eyebrow">Tag</div>
    <h1>{tag}</h1>
    <span class="count">/ {posts.length} post{posts.length === 1 ? '' : 's'}</span>
  </section>

  <section class="wrap feed">
    {posts.map((post) => (
      <div class="entry">
        <div class="date">{fmtDate(post.data.pubDate)}</div>
        <div>
          <h2><a class="entry-link" href={`/blog/${post.data.slug}/`}>{post.data.title}</a></h2>
          <p class="sum">{post.data.description}</p>
          <div class="tags">
            {post.data.tags.map((t) => <a href={`/tags/${slugifyTag(t)}`}>{t}</a>)}
          </div>
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
