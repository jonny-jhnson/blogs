---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const slugifyTag = (t) => t.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

const posts = await getCollection('blog', ({ data }) => !data.draft);

// Count posts per tag.
const counts = new Map();
for (const post of posts) {
  for (const tag of post.data.tags) {
    counts.set(tag, (counts.get(tag) ?? 0) + 1);
  }
}
const tags = [...counts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---
<BaseLayout title="Tags" description="Browse posts by topic.">
  <section class="wrap tag-head">
    <div class="eyebrow">Browse</div>
    <h1>Tags</h1>
    <span class="count">/ {tags.length} topics</span>
  </section>

  <section class="wrap">
    <div class="tag-cloud">
      {tags.map(([tag, n]) => (
        <a href={`/tags/${slugifyTag(tag)}`}>{tag}<span class="n">{n}</span></a>
      ))}
    </div>
  </section>
</BaseLayout>
